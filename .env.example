# ── Phase 2.5 (sheets severed — Supabase-only test env) ─────────────
# Metabase direct sync (cards 28816 stations + 28556 boxes)
METABASE_URL=https://metabase.vammo.com
METABASE_API_KEY=                 # x-api-key; Gabriel provides (n8n already holds one)
# n8n → app webhook for email cobranças (R2)
N8N_INGEST_SECRET=                # openssl rand -base64 32; Bearer on /api/ingest/cobrancas
# Vammo-Enel scraper → app ingestion feed (decision #34; separate secret so it rotates independently)
SCRAPER_INGEST_SECRET=            # openssl rand -base64 32; Bearer on /api/ingest/scraper
# FISCAL spreadsheet (NOT the scraper sheet — Q12): the duplicate check (read,
# decision #40) AND the send-to-fiscal append (write, decision #42). Grant the
# GSHEETS_SA_KEY_B64 service account EDITOR on it — write is needed for the send
# (Viewer alone only covers the check). Tabs are due-date months named 'MM-YYYY'.
FISCAL_SPREADSHEET_ID=            # Gabriel provides

# ── ARQIA (monitoramento de SIMs IoT, decisão #73) ───────────────────
# O app loga na API Arqia/gestaom2m (proxy.api.ip101.cloud) no cron diário.
# ⚠️ ROTACIONE a senha antes de usar (estava em texto puro no workflow n8n).
# Sem estas envs, o sync no-opa e a aba /arqia mostra "não configurado".
ARQIA_LOGIN=                      # e-mail de login na Arqia
ARQIA_PASSWORD=                   # senha (rotacionar!) — nunca commitar
ARQIA_API_KEY=                    # Ocp-Apim-Subscription-Key
ARQIA_CUSTOMER_ID=                # ex.: 101556
# ARQIA_ACCOUNT_FILTER=IOT FULL COMPARTILHADO   # opcional (default este)
# ARQIA_ALERT_THRESHOLD=80                       # opcional (default 80%) — alerta no cron diário
# Slack: bot com chat:write p/ os alertas de uso (o app manda a DM).
SLACK_BOT_TOKEN=                  # xoxb-… ; sem ele, alerta só fica no app
# ARQIA_ALERT_SLACK_USERS=U0A42QX2EJG,U083SU00P0V,U0AGGA84WAH  # opcional (default estes)

