# ── Phase 1 ──────────────────────────────────────────────────────────
# next-auth v5
AUTH_SECRET=                      # openssl rand -base64 32
AUTH_URL=http://localhost:3000    # production: https://<domain>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dev-only login bypass for local UI verification (NEVER set in Vercel).
# Requires NODE_ENV=development too — see auth.ts.
# AUTH_DEV_LOGIN=1

# Google Sheets (read-only service account; Viewer on both spreadsheets)
GSHEETS_SA_KEY_B64=               # base64 of the service-account JSON
SCRAPER_SPREADSHEET_ID=1MBJwXex56QkSWGJ0K8Unc-XDGjjZdCDu2SO8Ec5kIs8
RENT_SPREADSHEET_ID=18FxHr2F2ewv02jXjk95_cVmcmM19n9Hb20rBD6_L9ME

# ── Phase 2 (Supabase `charging` schema + jobs + Drive) ──────────────
# Shared "Vammo Automations" project (jfdqlnpidynxwqqiblcd).
NEXT_PUBLIC_SUPABASE_URL=https://jfdqlnpidynxwqqiblcd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # anon has zero grants on charging; bootstrap only
SUPABASE_SERVICE_ROLE_KEY=        # Sensitive; server-only (goBuy names it SUPABASE_SECRET_KEY)
SUPABASE_JWT_SECRET=              # legacy HS256 secret of the shared project (same goBuy uses)
CRON_SECRET=                      # openssl rand -base64 32; Bearer on /api/cron/*
REPOSITORY_BACKEND=sheets         # flip to 'supabase' at cutover
# Drive folders (service account needs Content Manager on all of these)
DRIVE_METER_PHOTOS_FOLDER_ID=1t7WoWRYxjBYrb8E6onBtfe773r0yNwRC
DRIVE_COMPROVANTES_FOLDER_ID=13nbLPM1akfR48YqYAtMKFcOEioD8jPsY
DRIVE_BILLS_FOLDER_ID=1AB8ok7Dl5euKe-_qt3axEeXPi1f4KbaS
# Contratos_Aluguel — the folder n8n's Fill_Cadastro_Form Drive trigger watches;
# the "Novo contrato" upload drops PDFs here so n8n extracts them (#48). The SA
# needs Content Manager (write) on it — decision #30 only granted read.
DRIVE_CONTRATOS_FOLDER_ID=1V6FQk5r2-3puqfHCDJbXkWFJkAVQbEJa
# SLACK_WEBHOOK_FINANCE=          # Phase 2 keeps n8n watchdogs; app Slack push deferred
